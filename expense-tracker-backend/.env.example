# Copy this to .env for local development (never commit .env to git)

# Option A: Full connection URL (used in cloud deployment on Render/Neon)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/expense_tracker

# Option B: Individual fields (used as fallback when DATABASE_URL is not set)
# DB_NAME=expense_tracker
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
